            <button class="ctrl-btn" id="btn-usgs" title="Eventos sísmicos USGS">🌋 USGS</button>
            <button class="ctrl-btn" id="btn-prospect" title="Heatmap de prospectividade (weighted overlay: ocorrências + Bouguer + geoquímica + estrutural)">🎯 Prospectividade</button>
            <button class="ctrl-btn" id="btn-bouguer" title="Gradiente horizontal do campo Bouguer — lineamentos gravimétricas (HGM)">🌐 Bouguer HGM</button>
            <button class="ctrl-btn" id="btn-aeromag-grid" title="Grade local de Anomalia Magnética Total (AeromagConnector — dados amostrados na sessão, proxy RGB)">🧲 Aeromag local</button>
