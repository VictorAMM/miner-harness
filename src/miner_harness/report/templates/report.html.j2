// ============================================================
// D2: SIDEBAR COLLAPSIBLE — setup único
// ============================================================
(function initSidebarCollapse() {
  var aside = document.querySelector('aside');
  if (!aside) return;
  aside.querySelectorAll('.sidebar-section').forEach(function(section) {
    var titleEl = section.querySelector('.section-title');
    if (!titleEl) return;
    // Criar wrapper para o conteúdo colapsável
    var body = document.createElement('div');
    body.className = 'section-body';
    // Mover todos os filhos do section (exceto o título) para o body
    Array.from(section.children).forEach(function(child) {
      if (child !== titleEl) body.appendChild(child);
    });
    section.appendChild(body);
    // Adicionar chevron ao título
    var chevron = document.createElement('span');
    chevron.className = 'section-chevron';
    chevron.textContent = '▼';
    titleEl.appendChild(chevron);
    // Definir max-height inicial para que a transição funcione
    body.style.maxHeight = body.scrollHeight + 'px';
    // Toggle ao clicar no título
    titleEl.addEventListener('click', function() {
      var collapsed = body.classList.toggle('collapsed');
      chevron.classList.toggle('collapsed', collapsed);
    });
  });
})();

// ============================================================
// D1: DRAG HANDLE — redimensionar painel inferior
// ============================================================
(function initDragHandle() {
  var handle = document.getElementById('drag-handle');
  var panel  = document.getElementById('bottom-panel');
  var mapCol = document.getElementById('map-col');
  if (!handle || !panel || !mapCol) return;

  var dragging = false;
  var startY, startH;

  handle.addEventListener('mousedown', function(e) {
    dragging = true;
    startY = e.clientY;
    startH = panel.getBoundingClientRect().height;
    handle.classList.add('dragging');
    document.body.style.cursor = 'ns-resize';
    document.body.style.userSelect = 'none';
    e.preventDefault();
  });

  document.addEventListener('mousemove', function(e) {
    if (!dragging) return;
    var delta = startY - e.clientY;  // arrastar para cima aumenta o painel
    var colH = mapCol.getBoundingClientRect().height;
    var newH = Math.min(Math.max(80, startH + delta), colH - 100);
    panel.style.flex = '0 0 ' + newH + 'px';
    map.invalidateSize();
  });

  document.addEventListener('mouseup', function() {
    if (!dragging) return;
    dragging = false;
    handle.classList.remove('dragging');
    document.body.style.cursor = '';
    document.body.style.userSelect = '';
    map.invalidateSize();
  });
})();

// ============================================================
// TAB SYSTEM — setup único
// ============================================================
document.querySelectorAll('.tab-btn').forEach(function(btn) {
  btn.addEventListener('click', function() {
    const tab = this.dataset.tab;
    document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
    document.querySelectorAll('.tab-pane').forEach(function(p) { p.classList.remove('active'); });
    this.classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
    if (tab === 'qualidade' && !window._chartsInited) {
      renderQualityCharts(CURRENT_REPORT);
    }
    map.invalidateSize();
  });
});

// Force map to correct size after layout settles
setTimeout(function() { map.invalidateSize(); }, 100);

{% if serve_mode %}
// ============================================================
// NOVA PESQUISA — SSE client
// ============================================================
(function initNovaPesquisa() {
  const STEP_ORDER = [
    'tectonic_history','structural_architecture',
    'magmatic_fertility','indirect_evidence','total_integration'
  ];
  const submitBtn = document.getElementById('np-submit');
  const errorEl = document.getElementById('np-error');
  const overlay = document.getElementById('progress-overlay');

  function showError(msg) { errorEl.textContent = msg; errorEl.style.display = ''; }
  function clearError() { errorEl.style.display = 'none'; }

  function validateForm() {
    const region = document.getElementById('np-region').value.trim();
    const lonMin = parseFloat(document.getElementById('np-lon-min').value);
    const latMin = parseFloat(document.getElementById('np-lat-min').value);
    const lonMax = parseFloat(document.getElementById('np-lon-max').value);
    const latMax = parseFloat(document.getElementById('np-lat-max').value);
    if (!region) return {error: 'Nome da região obrigatório.'};
    if ([lonMin, latMin, lonMax, latMax].some(isNaN)) return {error: 'Preencha todos os campos de coordenadas.'};
    if (lonMin >= lonMax) return {error: 'Lon Min deve ser menor que Lon Max.'};
    if (latMin >= latMax) return {error: 'Lat Min deve ser menor que Lat Max.'};
    return {region: region, bbox: {lon_min: lonMin, lat_min: latMin, lon_max: lonMax, lat_max: latMax}};
  }

  function initOverlay(region) {
    document.getElementById('np-progress-region').textContent = 'Região: ' + region;
    document.getElementById('np-progress-bar').style.width = '0%';
    document.getElementById('np-progress-status').textContent = 'Iniciando...';
    const stepsEl = document.getElementById('np-progress-steps');
    stepsEl.innerHTML = '';
    STEP_ORDER.forEach(function(s) {
      const el = document.createElement('div');
      el.id = 'np-step-' + s;
      el.style.cssText = 'display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text-muted)';
      el.innerHTML = '<span style="font-size:14px">○</span><span>' + (STEP_NAMES[s] || s) + '</span>';
      stepsEl.appendChild(el);
    });
    overlay.style.display = 'flex';
  }

  function markStep(step, active) {
    const el = document.getElementById('np-step-' + step);
    if (!el) return;
    const label = STEP_NAMES[step] || step;
    if (active) {
      el.innerHTML = '<span style="font-size:14px;color:var(--accent)">◉</span>'
        + '<span style="color:var(--accent)">' + label + '</span>';
    } else {
      el.innerHTML = '<span style="font-size:14px;color:var(--high)">✓</span>'
        + '<span style="color:var(--high)">' + label + '</span>';
    }
  }

  submitBtn.addEventListener('click', function() {
    clearError();
    var v = validateForm();
    if (v.error) { showError(v.error); return; }

    submitBtn.disabled = true;
    initOverlay(v.region);

    // POST para iniciar análise
    fetch('/api/analyze', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({region: v.region, bbox: v.bbox}),
    }).then(function(resp) {
      if (!resp.ok) {
        return resp.json().catch(function() { return {msg: resp.statusText}; }).then(function(d) {
          throw new Error(d.msg || 'Erro ao iniciar análise.');
        });
      }

      // Abre SSE stream
      var completedSteps = 0;
      var evtSource = new EventSource('/api/analyze/stream');

      evtSource.addEventListener('step_start', function(e) {
        var d = JSON.parse(e.data);
        document.getElementById('np-progress-status').textContent =
          'Executando: ' + (STEP_NAMES[d.step] || d.step);
        markStep(d.step, true);
        var etaEl = document.getElementById('np-progress-eta');
        if (etaEl) {
          if (d.eta_s != null && d.eta_s > 0) {
            var etaMins = Math.ceil(d.eta_s / 60);
            etaEl.textContent = '⏱ ~' + etaMins + ' min restante' + (etaMins !== 1 ? 's' : '');
            etaEl.style.display = 'block';
          } else if (d.step_index === 0) {
            etaEl.textContent = '⏱ calculando...';
            etaEl.style.display = 'block';
          }
        }
      });

      evtSource.addEventListener('step_complete', function(e) {
        var d = JSON.parse(e.data);
        completedSteps++;
        markStep(d.step, false);
        var pct = Math.round((completedSteps / STEP_ORDER.length) * 100);
        document.getElementById('np-progress-bar').style.width = pct + '%';
      });

      evtSource.addEventListener('complete', function(e) {
        evtSource.close();
        var d = JSON.parse(e.data);
        overlay.style.display = 'none';
        submitBtn.disabled = false;
        renderDashboard(d.report);
      });

      evtSource.addEventListener('error', function(e) {
        evtSource.close();
        overlay.style.display = 'none';
        submitBtn.disabled = false;
        var msg = 'Erro durante análise.';
        try { var d = JSON.parse(e.data); msg = d.msg || msg; } catch(ex) {}
        showError(msg);
      });

      evtSource.onerror = function() {
        if (evtSource.readyState === EventSource.CLOSED) {
          overlay.style.display = 'none';
          submitBtn.disabled = false;
          showError('Conexão com o servidor perdida.');
        }
      };

    }).catch(function(err) {
      overlay.style.display = 'none';
      submitBtn.disabled = false;
      showError(err.message || 'Erro de conexão.');
    });
  });
})();
{% endif %}
</script>
