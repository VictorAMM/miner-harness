      ${followup.length ? `<div class="tc-followup">${followup.map(function(f) { return `<span class="tc-followup-tag">${esc(f)}</span>`; }).join('')}</div>` : ''}
      <div style="margin-top:8px">
        <button class="btn-fly" onclick="flyToTarget(${idx})">📍 Ver no mapa</button>
      </div>
    `;
    grid.appendChild(card);
