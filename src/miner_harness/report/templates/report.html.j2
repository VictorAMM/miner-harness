<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>miner-harness — Relatório de Prospecção</title>
<!-- D4: Título dinâmico definido por JS após carga do relatório -->

<!-- Leaflet CSS embutido -->
<style>{{ leaflet_css }}</style>

<style>
/* ================================================================
   RESET & BASE
================================================================ */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:        #0f172a;
  --bg-card:   #1e293b;
  --bg-card2:  #263348;
  --border:    #334155;
  --text:      #f1f5f9;
  --text-muted:#94a3b8;
  --accent:    #f59e0b;
  --accent2:   #d97706;
  --high:      #22c55e;
  --medium:    #eab308;
  --low:       #f97316;
  --insuf:     #ef4444;
  --p1:        #ef4444;
  --p2:        #f97316;
  --p3:        #eab308;
  --p4:        #3b82f6;
  --p5:        #6b7280;
  --radius:    8px;
  --sidebar-w: 380px;
  --bottom-h:  40vh;
  --header-h:  54px;
}

body {
  font-family: system-ui, -apple-system, sans-serif;
  background: var(--bg);
  color: var(--text);
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  font-size: 14px;
}

/* ================================================================
   HEADER
================================================================ */
header {
  flex: 0 0 var(--header-h);
  background: var(--bg-card);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 0 20px;
  z-index: 1000;
}
header .brand {
  font-size: 15px;
  font-weight: 700;
  color: var(--accent);
  white-space: nowrap;
}
header .region {
  font-size: 16px;
  font-weight: 600;
  color: var(--text);
}
header .sep { color: var(--border); }
header .meta {
  color: var(--text-muted);
  font-size: 12px;
  white-space: nowrap;
}
header .quality-badge {
  padding: 3px 10px;
  border-radius: 12px;
  font-size: 12px;
  font-weight: 700;
  white-space: nowrap;
}
header .spacer { flex: 1; }

/* ================================================================
   DATA-COVERAGE BANNER
================================================================ */
#coverage-banner {
  display: none;
  background: #431407;
  border-bottom: 1px solid #ea580c;
  padding: 5px 20px;
  font-size: 11px;
  color: #fed7aa;
  gap: 8px;
  align-items: center;
  flex-shrink: 0;
}
#coverage-banner strong { color: #fb923c; }

/* ================================================================
   MAIN LAYOUT
================================================================ */
.layout {
  flex: 1;
  display: flex;
  min-height: 0;
  overflow: hidden;
}

/* ================================================================
   SIDEBAR
================================================================ */
aside {
  flex: 0 0 var(--sidebar-w);
  background: var(--bg-card);
  border-right: 1px solid var(--border);
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 0;
}

.sidebar-section {
  padding: 12px 14px;
  border-bottom: 1px solid var(--border);
}
.sidebar-section:last-child { border-bottom: none; }

.section-title {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  user-select: none;
}
.section-title:hover { color: var(--accent); }
.section-chevron {
  font-size: 9px;
  color: var(--text-muted);
  transition: transform 0.2s;
  flex-shrink: 0;
}
.section-chevron.collapsed { transform: rotate(-90deg); }
.section-body { overflow: hidden; transition: max-height 0.25s ease; }
.section-body.collapsed { max-height: 0 !important; }

/* Quality card */
.quality-card {
  display: flex;
  align-items: center;
  gap: 14px;
}
.quality-donut-wrap {
  position: relative;
  width: 72px;
  height: 72px;
  flex-shrink: 0;
}
.quality-donut-wrap canvas { width: 72px !important; height: 72px !important; }
.quality-score-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  font-weight: 700;
  color: var(--text);
}
.quality-meta { display: flex; flex-direction: column; gap: 3px; }
.quality-meta .q-row { display: flex; gap: 6px; font-size: 11px; }
.quality-meta .q-label { color: var(--text-muted); }
.quality-meta .q-val { color: var(--text); font-weight: 500; }

/* Target list */
.target-item {
  padding: 8px 10px;
  border-radius: var(--radius);
  cursor: pointer;
  transition: background 0.15s;
  margin-bottom: 4px;
  border: 1px solid transparent;
}
.target-item:hover { background: var(--bg-card2); }
.target-item.active { background: var(--bg-card2); border-color: var(--accent); }
.target-item .t-header {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 3px;
}
.target-item .t-priority {
  width: 22px; height: 22px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 700; color: white;
  flex-shrink: 0;
}
.target-item .t-name {
  font-weight: 600;
  font-size: 12px;
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.t-conf-badge {
  font-size: 10px;
  font-weight: 700;
  padding: 1px 6px;
  border-radius: 8px;
  white-space: nowrap;
  color: white;
}
.target-item .t-sub {
  font-size: 11px;
  color: var(--text-muted);
  margin-left: 28px;
  margin-bottom: 4px;
}
.btn-fly {
  margin-left: 28px;
  font-size: 10px;
  padding: 2px 8px;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  cursor: pointer;
  transition: all 0.15s;
}
.btn-fly:hover { border-color: var(--accent); color: var(--accent); }

/* Caveats */
.caveat-list { display: flex; flex-direction: column; gap: 5px; }
.caveat-item {
  font-size: 11px;
  color: var(--text-muted);
  background: rgba(239,68,68,0.08);
  border-left: 3px solid var(--insuf);
  padding: 5px 8px;
  border-radius: 0 4px 4px 0;
}

/* Map controls in sidebar — collapsible groups */
.map-group { margin-bottom: 8px; }
.map-group:last-child { margin-bottom: 0; }
.map-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-muted);
  padding: 4px 0;
  cursor: pointer;
  user-select: none;
  border-bottom: 1px solid var(--border);
  margin-bottom: 6px;
}
.map-group-header:hover { color: var(--accent); }
.map-group-chevron {
  font-size: 9px;
  transition: transform 0.2s;
}
.map-group.collapsed .map-group-chevron { transform: rotate(-90deg); }
.map-group-body {
  overflow: hidden;
  max-height: 600px;
  transition: max-height 0.25s ease;
}
.map-group.collapsed .map-group-body { max-height: 0; }
.map-ctrl-btns {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.ctrl-btn {
  padding: 7px 12px;
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text);
  cursor: pointer;
  font-size: 12px;
  text-align: left;
  transition: all 0.15s;
}
.ctrl-btn:hover { border-color: var(--accent); color: var(--accent); }
.ctrl-btn.inactive { opacity: 0.5; }
.sub-pills { display: flex; flex-wrap: wrap; gap: 4px; margin-top: 4px; }
.sub-pill {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 2px 7px; border-radius: 12px; font-size: 0.72rem;
  font-weight: 600; white-space: nowrap;
}
.sub-pill-dot {
  width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
}
.ocorr-total {
  font-size: 0.78rem; color: var(--fg2); margin-bottom: 6px;
}

/* ================================================================
   MAP
================================================================ */
#map-wrapper {
  flex: 1;
  position: relative;
  min-width: 0;
}
#map {
  position: absolute;
  inset: 0;
  background: #1a2332;
}

/* Aeromag local — legenda de gradiente */
.aeromag-gradient-bar {
  width: 100%;
  height: 8px;
  border-radius: 4px;
  background: linear-gradient(to right, #2563eb, #ffffff, #dc2626);
  margin: 3px 0 1px;
}
.aeromag-gradient-labels {
  display: flex;
  justify-content: space-between;
  font-size: 9px;
  color: var(--text-muted);
}

/* Leaflet popup dark theme */
.leaflet-popup-content-wrapper {
  background: var(--bg-card) !important;
  color: var(--text) !important;
  border: 1px solid var(--border) !important;
  border-radius: var(--radius) !important;
  box-shadow: 0 8px 32px rgba(0,0,0,0.5) !important;
}
.leaflet-popup-tip { background: var(--bg-card) !important; }
.leaflet-popup-content { margin: 10px 14px !important; min-width: 160px; max-width: 100%; word-break: break-word; overflow-wrap: break-word; }
.popup-title { font-weight: 700; font-size: 13px; margin-bottom: 6px; line-height: 1.3; }
.popup-row { display: flex; gap: 6px; font-size: 12px; margin-bottom: 2px; }
.popup-label { color: var(--text-muted); }
.popup-val { color: var(--text); }
.popup-rationale {
  margin-top: 6px;
  font-size: 11px;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  padding-top: 5px;
  max-height: 80px;
  overflow-y: auto;
}

/* Leaflet controls dark */
.leaflet-control-zoom a,
.leaflet-control-layers-toggle {
  background-color: var(--bg-card) !important;
  color: var(--text) !important;
  border-color: var(--border) !important;
}
.leaflet-control-layers {
  background: var(--bg-card) !important;
  border: 1px solid var(--border) !important;
  color: var(--text) !important;
}
.leaflet-control-attribution {
  background: rgba(15,23,42,0.7) !important;
  color: var(--text-muted) !important;
}
.leaflet-control-attribution a { color: var(--accent) !important; }

/* ================================================================
   DRAG HANDLE (entre mapa e painel inferior)
================================================================ */
.drag-handle {
  flex: 0 0 6px;
  background: var(--border);
  cursor: ns-resize;
  position: relative;
  transition: background 0.15s;
}
.drag-handle:hover, .drag-handle.dragging { background: var(--accent); }
.drag-handle::after {
  content: '';
  position: absolute;
  left: 50%; top: 50%;
  transform: translate(-50%, -50%);
  width: 32px; height: 3px;
  border-radius: 2px;
  background: rgba(255,255,255,0.25);
}

/* ================================================================
   BOTTOM PANEL
================================================================ */
.bottom-panel {
  flex: 0 0 var(--bottom-h);
  background: var(--bg-card);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  min-height: 80px;
}

.tab-bar {
  flex: 0 0 38px;
  display: flex;
  border-bottom: 1px solid var(--border);
  background: var(--bg);
}
.tab-btn {
  padding: 0 16px;
  height: 38px;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 12px;
  font-weight: 500;
  transition: all 0.15s;
  white-space: nowrap;
}
.tab-btn:hover { color: var(--text); }
.tab-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

.tab-contents { flex: 1; overflow: hidden; position: relative; }
.tab-pane {
  position: absolute;
  inset: 0;
  overflow-y: auto;
  padding: 12px 16px;
  display: none;
}
.tab-pane.active { display: block; }

/* ================================================================
   TAB: ANÁLISE — Accordion
================================================================ */
.integrated-summary-box {
  background: linear-gradient(135deg, #1e293b 60%, #0f2027);
  border: 1px solid var(--accent);
  border-left: 4px solid var(--accent);
  border-radius: 8px;
  padding: 14px 16px;
  margin-bottom: 16px;
}
.integrated-summary-box .is-label {
  font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--accent); margin-bottom: 8px;
}
.integrated-summary-box .is-text {
  font-size: 0.85rem; line-height: 1.65; color: var(--fg1);
}
.step-accordion { margin-bottom: 6px; }
.step-accordion--warn .step-header {
  border-left: 3px solid var(--low);
  padding-left: 7px;
}
.step-accordion--warn .step-header.open { border-left-color: var(--low); }
.step-warn-icon { font-size: 11px; margin-right: 2px; }
.step-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px 10px;
  background: var(--bg-card2);
  border-radius: var(--radius);
  cursor: pointer;
  user-select: none;
  border: 1px solid var(--border);
  transition: background 0.15s;
}
.step-header:hover { background: var(--border); }
.step-header.open { border-bottom-left-radius: 0; border-bottom-right-radius: 0; border-bottom-color: transparent; }
.step-chevron { font-size: 10px; color: var(--text-muted); transition: transform 0.2s; }
.step-header.open .step-chevron { transform: rotate(90deg); }
.step-name { font-weight: 600; font-size: 12px; flex: 1; }
.step-agent { font-size: 10px; color: var(--text-muted); }
.step-body {
  display: none;
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-top: none;
  border-radius: 0 0 var(--radius) var(--radius);
  padding: 10px 12px;
}
.step-body.open { display: block; }

.step-summary { font-size: 12px; color: var(--text-muted); margin-bottom: 8px; }
.step-findings { margin-bottom: 8px; }
.finding-item {
  font-size: 11px;
  padding: 3px 0;
  display: flex;
  gap: 6px;
  border-bottom: 1px solid rgba(51,65,85,0.4);
}
.finding-item::before { content: "•"; color: var(--accent); flex-shrink: 0; }
.step-meta { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 8px; }
.meta-block { font-size: 10px; }
.meta-block .meta-label { color: var(--text-muted); margin-bottom: 2px; }
.meta-block .meta-vals { color: var(--text); }
.reasoning-toggle {
  font-size: 11px;
  color: var(--accent);
  cursor: pointer;
  padding: 3px 0;
  display: inline-flex;
  align-items: center;
  gap: 4px;
  opacity: 0.8;
}
.reasoning-toggle:hover { opacity: 1; }
.reasoning-text {
  display: none;
  margin-top: 6px;
  font-size: 10px;
  color: var(--text-muted);
  background: var(--bg);
  border-radius: 4px;
  padding: 8px;
  max-height: 120px;
  overflow-y: auto;
  white-space: pre-wrap;
  word-break: break-word;
}

/* G3 — Nota de recalibração de confiança */
.calibration-note {
  margin-top: 6px;
  font-size: 10px;
  color: #fbbf24;
  background: rgba(251,191,36,0.08);
  border-left: 3px solid #fbbf24;
  border-radius: 0 4px 4px 0;
  padding: 4px 8px;
  line-height: 1.4;
}
.calibration-note::before {
  content: "⚠ ";
  font-weight: 700;
}

/* G11 — Banner de diversidade removida */
.diversity-removed-note {
  font-size: 11px;
  color: var(--text-muted);
  background: rgba(148,163,184,0.08);
  border: 1px dashed var(--border);
  border-radius: 6px;
  padding: 6px 10px;
  margin-bottom: 10px;
}

/* ================================================================
   TAB: ALVOS — Cards
================================================================ */
.targets-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 10px; }
.target-card {
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 12px;
}
.target-card .tc-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 8px;
}
.tc-priority-badge {
  width: 26px; height: 26px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 700; color: white;
  flex-shrink: 0;
}
.tc-name { font-weight: 700; font-size: 13px; flex: 1; }
.tc-row {
  display: flex;
  gap: 6px;
  margin-bottom: 5px;
  font-size: 11px;
  align-items: baseline;
}
.tc-label { color: var(--text-muted); min-width: 80px; }
.tc-val { color: var(--text); }
.tc-rationale {
  margin-top: 8px;
  font-size: 11px;
  color: var(--text-muted);
  border-top: 1px solid var(--border);
  padding-top: 6px;
  line-height: 1.5;
}
.tc-followup { margin-top: 6px; display: flex; flex-wrap: wrap; gap: 4px; }
.tc-followup-tag {
  font-size: 10px;
  padding: 2px 7px;
  background: rgba(245,158,11,0.15);
  border: 1px solid rgba(245,158,11,0.3);
  border-radius: 10px;
  color: var(--accent);
}

/* ================================================================
   TAB: QUALIDADE — Charts
================================================================ */
.quality-charts {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 12px;
}
.chart-card {
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 10px;
}
.chart-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  margin-bottom: 8px;
}
.chart-card canvas { max-height: 200px; }

/* ================================================================
   TAB: JSON
================================================================ */
.json-wrap { position: relative; }
.json-copy-btn {
  position: sticky;
  top: 0;
  float: right;
  padding: 4px 12px;
  background: var(--bg-card2);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text-muted);
  cursor: pointer;
  font-size: 11px;
  margin-bottom: 8px;
}
.json-copy-btn:hover { color: var(--accent); border-color: var(--accent); }
.json-pre {
  font-family: 'Courier New', monospace;
  font-size: 11px;
  color: #cbd5e1;
  white-space: pre;
  line-height: 1.5;
  background: var(--bg);
  padding: 10px;
  border-radius: 4px;
  overflow-x: auto;
}

/* ================================================================
   EMPTY STATE
================================================================ */
.empty-state {
  text-align: center;
  padding: 24px;
  color: var(--text-muted);
  font-size: 12px;
}
/* ================================================================
   PRINT (D5)
================================================================ */
@media print {
  body {
    background: white !important;
    color: #111 !important;
    height: auto !important;
    overflow: visible !important;
    font-size: 10pt !important;
  }
  header {
    background: white !important;
    border-bottom: 1px solid #ccc !important;
    position: static !important;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  header .brand { color: #b45309 !important; }
  header .region { color: #111 !important; }
  header .meta, header .sep { color: #555 !important; }
  #coverage-banner { display: none !important; }
  .layout {
    display: block !important;
    height: auto !important;
    overflow: visible !important;
  }
  aside {
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    overflow: visible !important;
    border-right: none !important;
    border-bottom: 1px solid #ccc !important;
    page-break-after: always;
  }
  #map-col {
    display: block !important;
    height: auto !important;
  }
  #map-wrapper {
    height: 400px !important;
    page-break-after: always;
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
  .drag-handle { display: none !important; }
  .bottom-panel {
    position: static !important;
    height: auto !important;
    max-height: none !important;
    border-top: 1px solid #ccc !important;
    overflow: visible !important;
    background: white !important;
  }
  .tab-bar { display: none !important; }
  .tab-content {
    display: block !important;
    max-height: none !important;
    overflow: visible !important;
  }
  .sidebar-section {
    break-inside: avoid;
    background: white !important;
    border: 1px solid #ddd !important;
    margin-bottom: 6px;
    border-radius: 6px;
  }
  .section-title { color: #555 !important; }
  .section-body.collapsed { max-height: none !important; }
  .target-card, .step-card, .target-item {
    break-inside: avoid;
    background: white !important;
    border: 1px solid #ddd !important;
  }
  .ctrl-btn, button:not(.btn-fly), #btn-centralizar,
  #btn-bbox, #btn-all-targets { display: none !important; }
  a { color: #111 !important; text-decoration: none !important; }
  .quality-badge { color: #111 !important; }
  .text-muted, .q-label, .step-summary, .t-sub { color: #555 !important; }
  .step-badge, .t-conf-badge {
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;
  }
}
{% if serve_mode %}
/* ================================================================
   NOVA PESQUISA
================================================================ */
.np-label { display: block; font-size: 10px; color: var(--text-muted); margin-bottom: 3px; }
.np-input {
  width: 100%; padding: 5px 8px;
  background: var(--bg); border: 1px solid var(--border);
  border-radius: 6px; color: var(--text); font-size: 12px; outline: none;
}
.np-input:focus { border-color: var(--accent); }
.np-form-row { margin-bottom: 6px; }
.np-submit-btn {
  width: 100%; text-align: center;
  background: rgba(245,158,11,0.15);
  border-color: rgba(245,158,11,0.5);
  color: var(--accent);
}
.np-submit-btn:hover { background: rgba(245,158,11,0.25); }
.np-submit-btn:disabled { opacity: 0.5; cursor: not-allowed; pointer-events: none; }
{% endif %}
</style>
</head>

