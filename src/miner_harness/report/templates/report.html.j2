      html += '<td style="padding:.3rem .6rem;font-family:monospace">' + lat + ', ' + lon + '</td>';
      html += '</tr>';
    });
    if (grav.length > 100) html += '<tr><td colspan="5" style="padding:.4rem .6rem;color:#6b7280">… e mais ' + (grav.length - 100) + ' registros</td></tr>';
    html += '</tbody></table></div>';
  }

  html += '<hr style="margin:1.2rem 0;border-color:#334155">';

  // --- Geoquímica ---
  var geoquim = geo['geoquimica'] || [];
  html += '<h3 style="margin:0 0 .5rem;color:#7c3aed">🧪 GeoSGB — Geoquímica</h3>';
  if (!geoquim.length) {
    html += '<p style="color:#6b7280">Sem amostras geoquímicas para esta região.</p>';
  } else {
    html += '<p style="color:#6b7280;margin:0 0 .5rem">' + geoquim.length + ' amostra(s) geoquímica(s) encontrada(s)</p>';
    html += '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:.82rem">';
    html += '<thead><tr style="background:#faf5ff">';
    ['Projeto','Classe','Material','Rocha Matriz','Análises (elementos)','Coord (lat, lon)'].forEach(function(h) {
