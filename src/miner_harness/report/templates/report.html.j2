      html += '<td style="padding:.3rem .6rem;text-align:right">' + (d.erro_ma != null ? '±' + Number(d.erro_ma).toFixed(1) : '—') + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (d.material || '—') + '</td>';
