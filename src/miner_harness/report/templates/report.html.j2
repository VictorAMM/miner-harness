      html += '<td style="padding:.3rem .6rem">' + (q.material_coletado || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (q.rocha_matriz || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem;text-align:right;color:#7c3aed">' + nAnalises + '</td>';
      html += '<td style="padding:.3rem .6rem;font-family:monospace">' + lat + ', ' + lon + '</td>';
      html += '</tr>';
    });
    if (geoquim.length > 100) html += '<tr><td colspan="6" style="padding:.4rem .6rem;color:#6b7280">… e mais ' + (geoquim.length - 100) + ' registros</td></tr>';
    html += '</tbody></table></div>';
  }

  html += '<hr style="margin:1.2rem 0;border-color:#334155">';

  // --- Litoestratigrafia ---
  var lito = geo['litoestratigrafia'] || [];
  html += '<h3 style="margin:0 0 .5rem;color:#0ea5e9">🗺 GeoSGB — Litoestratigrafia</h3>';
  if (!lito.length) {
    if (bboxFiltered.has('litoestratigrafia')) {
      html += '<p style="color:#d97706">⚠ Dados retornados pela API mas todas as unidades estão fora da área de interesse. Consulte as ressalvas.</p>';
    } else {
      html += '<p style="color:#6b7280">Sem unidades litoestratigráficas para esta região.</p>';
    }
  } else {
    html += '<p style="color:#6b7280;margin:0 0 .5rem">' + lito.length + ' unidade(s) litoestratigráfica(s) encontrada(s)</p>';
    html += '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:.82rem">';
    html += '<thead><tr style="background:#f0f9ff">';
    ['Sigla','Nome','Hierarquia','Litologia Principal','Idade','Coord (lat, lon)'].forEach(function(h) {
      html += '<th style="padding:.4rem .6rem;text-align:left;border-bottom:2px solid #0ea5e922;white-space:nowrap">' + h + '</th>';
    });
    html += '</tr></thead><tbody>';
    lito.slice(0, 100).forEach(function(u, i) {
      var bg = i % 2 ? '#f0f9ff' : '#fff';
      var coord = u.coordenada || {};
      var lat = coord.latitude != null ? Number(coord.latitude).toFixed(4) : '?';
      var lon = coord.longitude != null ? Number(coord.longitude).toFixed(4) : '?';
      var hier = u.hierarquia || '—';
      var color = _litoColor(u.hierarquia);
      html += '<tr style="background:' + bg + '">';
      html += '<td style="padding:.3rem .6rem;font-weight:700;color:' + color + '">' + (u.sigla || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (u.nome || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem"><span style="display:inline-block;width:8px;height:8px;border-radius:2px;background:' +
        color + ';margin-right:5px;vertical-align:middle"></span>' + hier + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (u.litologia_principal || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (u.idade || '—') + '</td>';
      html += '<td style="padding:.3rem .6rem;font-family:monospace">' + lat + ', ' + lon + '</td>';
      html += '</tr>';
    });
    if (lito.length > 100) html += '<tr><td colspan="6" style="padding:.4rem .6rem;color:#6b7280">… e mais ' + (lito.length - 100) + ' registros</td></tr>';
    html += '</tbody></table></div>';
  }

  html += '<hr style="margin:1.2rem 0;border-color:#334155">';

  // --- USGS ---
  html += '<h3 style="margin:0 0 .5rem;color:#ea580c">🌋 USGS — Eventos Sísmicos</h3>';
  if (!usgs.length) {
    html += '<p style="color:#6b7280">Sem eventos sísmicos para esta região (mag ≥ ' + (r.usgs_min_magnitude || 2.0) + ').</p>';
  } else {
    html += '<p style="color:#6b7280;margin:0 0 .5rem">' + usgs.length + ' evento(s) sísmico(s) encontrado(s)</p>';
    html += '<div style="overflow-x:auto"><table style="width:100%;border-collapse:collapse;font-size:.82rem">';
    html += '<thead><tr style="background:#1e293b">';
    ['Magnitude','Profundidade (km)','Local','Coord (lat, lon)'].forEach(function(h) {
      html += '<th style="padding:.4rem .6rem;text-align:left;border-bottom:2px solid #ea580c22;white-space:nowrap">' + h + '</th>';
    });
    html += '</tr></thead><tbody>';
    usgs.slice(0, 50).forEach(function(e, i) {
      var bg = i % 2 ? '#fffbf7' : '#fff';
      var coord = e.coordenada || {};
      html += '<tr style="background:' + bg + '">';
      html += '<td style="padding:.3rem .6rem;font-weight:700;color:#ea580c">M' + Number(e.magnitude).toFixed(1) + '</td>';
      html += '<td style="padding:.3rem .6rem;text-align:right">' + Number(e.profundidade_km).toFixed(1) + '</td>';
      html += '<td style="padding:.3rem .6rem">' + (e.lugar || '—') + '</td>';
      var lat = coord.latitude != null ? Number(coord.latitude).toFixed(4) : '?';
      var lon = coord.longitude != null ? Number(coord.longitude).toFixed(4) : '?';
      html += '<td style="padding:.3rem .6rem;font-family:monospace">' + lat + ', ' + lon + '</td>';
      html += '</tr>';
    });
    if (usgs.length > 50) html += '<tr><td colspan="4" style="padding:.4rem .6rem;color:#6b7280">… e mais ' + (usgs.length - 50) + ' registros</td></tr>';
    html += '</tbody></table></div>';
  }

  html += '</div>';
  el.innerHTML = html;
}
