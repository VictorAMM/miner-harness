// ============================================================
// NOVA PESQUISA — SSE client
// ============================================================
(function initNovaPesquisa() {
  const STEP_ORDER = [
    'tectonic_history','structural_architecture',
    'magmatic_fertility','indirect_evidence','total_integration'
  ];
  const submitBtn = document.getElementById('np-submit');
  const errorEl = document.getElementById('np-error');
  const overlay = document.getElementById('progress-overlay');

  function showError(msg) { errorEl.textContent = msg; errorEl.style.display = ''; }
  function clearError() { errorEl.style.display = 'none'; }

  function validateForm() {
    const region = document.getElementById('np-region').value.trim();
    const lonMin = parseFloat(document.getElementById('np-lon-min').value);
    const latMin = parseFloat(document.getElementById('np-lat-min').value);
    const lonMax = parseFloat(document.getElementById('np-lon-max').value);
    const latMax = parseFloat(document.getElementById('np-lat-max').value);
    if (!region) return {error: 'Nome da região obrigatório.'};
    if ([lonMin, latMin, lonMax, latMax].some(isNaN)) return {error: 'Preencha todos os campos de coordenadas.'};
    if (lonMin >= lonMax) return {error: 'Lon Min deve ser menor que Lon Max.'};
    if (latMin >= latMax) return {error: 'Lat Min deve ser menor que Lat Max.'};
    return {region: region, bbox: {lon_min: lonMin, lat_min: latMin, lon_max: lonMax, lat_max: latMax}};
  }

  function initOverlay(region) {
    document.getElementById('np-progress-region').textContent = 'Região: ' + region;
    document.getElementById('np-progress-bar').style.width = '0%';
    document.getElementById('np-progress-status').textContent = 'Iniciando...';
    const stepsEl = document.getElementById('np-progress-steps');
    stepsEl.innerHTML = '';
    STEP_ORDER.forEach(function(s) {
      const el = document.createElement('div');
      el.id = 'np-step-' + s;
      el.style.cssText = 'display:flex;align-items:center;gap:8px;font-size:12px;color:var(--text-muted)';
      el.innerHTML = '<span style="font-size:14px">○</span><span>' + (STEP_NAMES[s] || s) + '</span>';
      stepsEl.appendChild(el);
    });
    overlay.style.display = 'flex';
  }

  function markStep(step, active) {
    const el = document.getElementById('np-step-' + step);
    if (!el) return;
    const label = STEP_NAMES[step] || step;
    if (active) {
      el.innerHTML = '<span style="font-size:14px;color:var(--accent)">◉</span>'
        + '<span style="color:var(--accent)">' + label + '</span>';
    } else {
      el.innerHTML = '<span style="font-size:14px;color:var(--high)">✓</span>'
        + '<span style="color:var(--high)">' + label + '</span>';
    }
  }

  submitBtn.addEventListener('click', function() {
    clearError();
    var v = validateForm();
    if (v.error) { showError(v.error); return; }

    submitBtn.disabled = true;
    initOverlay(v.region);

    // POST para iniciar análise
    fetch('/api/analyze', {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({region: v.region, bbox: v.bbox}),
    }).then(function(resp) {
      if (!resp.ok) {
        return resp.json().catch(function() { return {msg: resp.statusText}; }).then(function(d) {
          throw new Error(d.msg || 'Erro ao iniciar análise.');
        });
      }

      // Abre SSE stream
      var completedSteps = 0;
      var evtSource = new EventSource('/api/analyze/stream');

      evtSource.addEventListener('step_start', function(e) {
        var d = JSON.parse(e.data);
        document.getElementById('np-progress-status').textContent =
          'Executando: ' + (STEP_NAMES[d.step] || d.step);
        markStep(d.step, true);
      });

      evtSource.addEventListener('step_complete', function(e) {
        var d = JSON.parse(e.data);
        completedSteps++;
        markStep(d.step, false);
        var pct = Math.round((completedSteps / STEP_ORDER.length) * 100);
        document.getElementById('np-progress-bar').style.width = pct + '%';
      });

      evtSource.addEventListener('complete', function(e) {
        evtSource.close();
        var d = JSON.parse(e.data);
        overlay.style.display = 'none';
        submitBtn.disabled = false;
        renderDashboard(d.report);
      });

      evtSource.addEventListener('error', function(e) {
        evtSource.close();
        overlay.style.display = 'none';
        submitBtn.disabled = false;
        var msg = 'Erro durante análise.';
        try { var d = JSON.parse(e.data); msg = d.msg || msg; } catch(ex) {}
        showError(msg);
      });

      evtSource.onerror = function() {
        if (evtSource.readyState === EventSource.CLOSED) {
          overlay.style.display = 'none';
          submitBtn.disabled = false;
          showError('Conexão com o servidor perdida.');
        }
      };

    }).catch(function(err) {
      overlay.style.display = 'none';
      submitBtn.disabled = false;
      showError(err.message || 'Erro de conexão.');
    });
  });
})();
{% endif %}
</script>
</body>
</html>
