function renderJsonTab(r) {
  const pane = document.getElementById('tab-json');
  const pretty = JSON.stringify(r, null, 2);
  pane.innerHTML = `
    <div class="json-wrap">
      <button class="json-copy-btn" id="btn-copy-json">📋 Copiar JSON</button>
      <pre class="json-pre">${esc(pretty)}</pre>
    </div>
  `;
  document.getElementById('btn-copy-json').onclick = function() {
    navigator.clipboard.writeText(pretty).then(function() {
      document.getElementById('btn-copy-json').textContent = '✓ Copiado!';
      setTimeout(function() { document.getElementById('btn-copy-json').textContent = '📋 Copiar JSON'; }, 2000);
    });
  };
}

