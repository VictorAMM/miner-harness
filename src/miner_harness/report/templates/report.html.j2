    html += '</tbody></table></div>';
  }

  html += '<hr style="margin:1.2rem 0;border-color:#334155">';

  // --- Gravimetria ---
  var grav = geo['gravimetria'] || [];
  html += '<h3 style="margin:0 0 .5rem;color:#0f766e">📐 GeoSGB — Gravimetria</h3>';
  if (!grav.length) {
