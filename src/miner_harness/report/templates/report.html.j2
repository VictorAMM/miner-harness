// flyTo reutiliza targetLayers, que é reconstruído por renderMapForReport
function flyToTarget(idx) {
  const layer = targetLayers[idx];
  if (!layer) return;
  map.flyTo([layer.target.latitude, layer.target.longitude], 11, {duration: 1.2});
  setTimeout(function() { layer.marker.openPopup(); }, 1300);
  document.querySelectorAll('.target-item').forEach(function(el) { el.classList.remove('active'); });
  const el = document.querySelector('[data-target-idx="' + idx + '"]');
  if (el) el.classList.add('active');
}

// ============================================================
// SIDEBAR — TARGETS LIST
// ============================================================
function renderTargetsList(r) {
  const container = document.getElementById('targets-list');
  container.innerHTML = '';
  if (r.targets.length === 0) {
    container.innerHTML = '<div class="empty-state">Sem alvos identificados.</div>';
    return;
  }

  r.targets.forEach(function(t, idx) {
    const color = PRIORITY_COLORS[t.priority] || '#6b7280';
    const cColor = CONF_COLORS[t.confidence] || '#6b7280';
    const cLabel = CONF_LABELS[t.confidence] || t.confidence;
    const comms = (t.commodities || []).join(', ');

    const item = document.createElement('div');
    item.className = 'target-item';
    item.dataset.targetIdx = idx;
    const cTip = CONF_TOOLTIPS[t.confidence] || '';
    item.innerHTML = `
      <div class="t-header">
        <div class="t-priority" style="background:${color}">P${t.priority}</div>
        <div class="t-name">${t.name}</div>
        <span class="t-conf-badge" style="background:${cColor}22;color:${cColor}"
              title="${cTip}">${cLabel}</span>
      </div>
      <div class="t-sub">${comms} · ${t.mineral_system}</div>
      <button class="btn-fly" onclick="flyToTarget(${idx})">📍 Ver no mapa</button>
    `;
    item.addEventListener('click', function(e) {
      if (e.target.tagName === 'BUTTON') return;
      flyToTarget(idx);
    });
    container.appendChild(item);
  });
}

