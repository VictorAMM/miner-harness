// ============================================================
// SIDEBAR — OCORRÊNCIAS STATS
// ============================================================
function renderOcorrenciasStats(r) {
  var section = document.getElementById('ocorr-stats-section');
  var content = document.getElementById('ocorr-stats-content');
  if (!section || !content) return;

  var geo = r.geological_data || {};
  var ocorr = geo['ocorrencias'] || [];
  if (ocorr.length === 0) { section.style.display = 'none'; return; }
  section.style.display = '';

  // Agrupar por substância e contar
  var counts = {};
  ocorr.forEach(function(o) {
    var sub = (o.substancias || 'Desconhecida').trim();
    counts[sub] = (counts[sub] || 0) + 1;
  });

  // Ordenar por contagem decrescente
  var entries = Object.entries(counts).sort(function(a, b) { return b[1] - a[1]; });

  var html = '<div class="ocorr-total">' + ocorr.length + ' ocorrência(s) na região</div>';
  html += '<div class="sub-pills">';
  entries.forEach(function(entry) {
    var sub = entry[0];
    var cnt = entry[1];
    var color = substanciaColor(sub);
    // Label compacto: remover vírgulas redundantes, limitar a 14 chars
    var label = sub.length > 16 ? sub.slice(0, 15) + '…' : sub;
    html += '<span class="sub-pill" style="background:' + color + '22;color:' + color + '" title="' + sub + '">' +
      '<span class="sub-pill-dot" style="background:' + color + '"></span>' +
      label + ' <b>×' + cnt + '</b></span>';
  });
  html += '</div>';
  content.innerHTML = html;
}

// ============================================================
// TAB: ANÁLISE
// ============================================================
function renderAnaliseTab(r) {
  const pane = document.getElementById('tab-analise');
  pane.innerHTML = '';
  if (r.steps.length === 0) {
    pane.innerHTML = '<div class="empty-state">Sem passos de análise disponíveis.</div>';
    return;
  }

  // Síntese integrada do Evaluator — exibida no topo da aba, antes dos steps
  if (r.integrated_summary) {
    const box = document.createElement('div');
    box.className = 'integrated-summary-box';
    box.innerHTML =
      '<div class="is-label">🔬 Síntese Integrada — Dr. Augusto Valen</div>' +
      '<div class="is-text">' + esc(r.integrated_summary) + '</div>';
    pane.appendChild(box);
  }

  r.steps.forEach(function(step, si) {
    const conf = step.confidence || 'insufficient';
    const cColor = CONF_COLORS[conf] || '#6b7280';
    const cLabel = CONF_LABELS[conf] || conf;
    const sName = stepName(step.step);
    const agent = step.agent || '';
    const dur = durFmt(step.duration_ms || 0);

    const findings = (step.findings || []).slice(0, 10);
    // D6: usar rótulos humanos para as fontes de dados
    const sourcesArr = (step.data_sources_used || []).map(humanSource);
    const sources = sourcesArr.join(', ') || '—';
    const gaps = (step.data_gaps || []).join(', ') || '—';
    // D1+D2: strip de <think> tokens; separar por agente usando step.agent
    const rawReasoning = step.raw_reasoning || '';
    const agentNames = (step.agent || '').split(' + ').map(function(s) { return s.trim(); });
    const reasoningParts = rawReasoning.split(' | ').filter(Boolean);

    const findingsHtml = findings.length
      ? findings.map(function(f) { return `<div class="finding-item">${esc(f)}</div>`; }).join('')
      : '<div style="color:var(--text-muted);font-size:11px">Sem achados.</div>';

    const isWarn = conf === 'low' || conf === 'insufficient';
    const cTipStep = CONF_TOOLTIPS[conf] || '';
    const warnIcon = isWarn ? '<span class="step-warn-icon" title="Confiança baixa — ver nota de recalibração abaixo">⚠</span>' : '';

    // G3 — nota de recalibração separada dos data_gaps
    const calibNote = step.calibration_note || '';
    const calibHtml = calibNote
      ? `<div class="calibration-note">${esc(calibNote)}</div>`
      : '';

    const acc = document.createElement('div');
    acc.className = 'step-accordion' + (isWarn ? ' step-accordion--warn' : '');
    acc.innerHTML = `
      <div class="step-header" data-si="${si}">
        <span class="step-chevron">▶</span>
        ${warnIcon}<span class="step-name">${sName}</span>
        <span class="step-agent">${agent}</span>
        <span class="t-conf-badge" style="background:${cColor}22;color:${cColor}"
              title="${cTipStep}">${cLabel}</span>
        <span style="font-size:10px;color:var(--text-muted);margin-left:4px">${dur}</span>
      </div>
      <div class="step-body" data-si="${si}">
        <div class="step-summary">${esc(step.summary || '')}</div>
        <div class="step-findings">${findingsHtml}</div>
        ${calibHtml}
        <div class="step-meta">
          <div class="meta-block">
            <div class="meta-label">Fontes usadas</div>
            <div class="meta-vals">${esc(sources)}</div>
          </div>
          <div class="meta-block">
            <div class="meta-label">Lacunas</div>
            <div class="meta-vals">${esc(gaps)}</div>
          </div>
        </div>
        ${reasoningParts.length > 0 ? `
          <div class="reasoning-toggle" data-si="${si}" data-count="${reasoningParts.length}" data-multi="${agentNames.length > 1}">▶ Raciocínio ${reasoningParts.length > 1 ? '(' + agentNames.join(' + ') + ')' : 'do agente'}</div>
          <div class="reasoning-text" data-si="${si}">${
            reasoningParts.length > 1
              ? reasoningParts.map(function(p, pi) {
                  var label = agentNames[pi] || ('agente ' + (pi + 1));
                  var cleaned = esc(stripThinking(p).slice(0, 1200));
                  var overflow = stripThinking(p).length > 1200;
                  return '<div style="margin-bottom:8px;padding:5px 8px;background:rgba(245,158,11,0.06);border-left:2px solid var(--accent);border-radius:0 4px 4px 0">' +
                    '<div style="font-size:9px;font-weight:700;color:var(--accent);margin-bottom:3px;text-transform:uppercase;letter-spacing:.06em">🔬 ' + label + '</div>' +
                    cleaned + (overflow ? '<span style="color:#94a3b8">…</span>' : '') + '</div>';
                }).join('')
              : (function() {
                  var cleaned = stripThinking(reasoningParts[0]);
                  return esc(cleaned.slice(0, 2000)) + (cleaned.length > 2000 ? '<span style="color:#94a3b8">…</span>' : '');
                })()
          }</div>
        ` : ''}
      </div>
    `;
    pane.appendChild(acc);
  });

  pane.addEventListener('click', function(e) {
    const header = e.target.closest('.step-header');
    if (header) {
      const si = header.dataset.si;
      const body = pane.querySelector('.step-body[data-si="' + si + '"]');
      header.classList.toggle('open');
      body.classList.toggle('open');
      return;
    }
    const rtoggle = e.target.closest('.reasoning-toggle');
    if (rtoggle) {
      const si = rtoggle.dataset.si;
      const rt = pane.querySelector('.reasoning-text[data-si="' + si + '"]');
      const open = rt.style.display === 'block';
      rt.style.display = open ? 'none' : 'block';
      const count = parseInt(rtoggle.dataset.count || '1');
      const multi = rtoggle.dataset.multi === 'true';
      // Reconstruir label preservando nomes dos agentes
      const agentLabel = multi
        ? rtoggle.textContent.replace(/^[▶▼] Raciocínio /, '')
        : 'do agente';
      rtoggle.textContent = (open ? '▶' : '▼') + ' Raciocínio ' + agentLabel;
    }
  });

  const firstHeader = pane.querySelector('.step-header');
  const firstBody = pane.querySelector('.step-body');
  if (firstHeader && firstBody) {
    firstHeader.classList.add('open');
    firstBody.classList.add('open');
  }
}

// ============================================================
// TAB: ALVOS
// ============================================================
function renderAlvosTab(r) {
  const pane = document.getElementById('tab-alvos');
  pane.innerHTML = '';
  if (r.targets.length === 0) {
    pane.innerHTML = '<div class="empty-state">Sem alvos identificados no relatório.</div>';
    return;
  }

  // G11 — nota de alvos removidos por diversidade espacial
  const divRemoved = r.diversity_removed_count || 0;
  if (divRemoved > 0) {
    const divNote = document.createElement('div');
    divNote.className = 'diversity-removed-note';
    divNote.innerHTML = `ℹ️ ${divRemoved} alvo(s) próximo(s) removido(s) por diversidade espacial ` +
      `(distância &lt;15 km de alvo de maior prioridade). ` +
      `Regiões com múltiplos alvos próximos indicam maior incerteza geológica.`;
    pane.appendChild(divNote);
  }

  // Contexto executivo acima dos cards de alvos
  if (r.integrated_summary) {
    const box = document.createElement('div');
    box.className = 'integrated-summary-box';
    box.style.marginBottom = '20px';
    box.innerHTML =
      '<div class="is-label">📋 Contexto da análise</div>' +
      '<div class="is-text">' + esc(r.integrated_summary) + '</div>';
    pane.appendChild(box);
  }

  const grid = document.createElement('div');
  grid.className = 'targets-grid';

  r.targets.forEach(function(t, idx) {
    const color = PRIORITY_COLORS[t.priority] || '#6b7280';
    const cColor = CONF_COLORS[t.confidence] || '#6b7280';
    const cLabel = CONF_LABELS[t.confidence] || t.confidence;
    const comms = (t.commodities || []).join(', ');
    const followup = (t.recommended_followup || []);

    const card = document.createElement('div');
    card.className = 'target-card';
    card.innerHTML = `
      <div class="tc-header">
        <div class="tc-priority-badge" style="background:${color}">P${t.priority}</div>
        <div class="tc-name">${esc(t.name)}</div>
        <span class="t-conf-badge" style="background:${cColor}22;color:${cColor}">${cLabel}</span>
      </div>
      <div class="tc-row"><span class="tc-label">Commodities</span><span class="tc-val">${esc(comms)}</span></div>
      <div class="tc-row"><span class="tc-label">Sistema mineral</span><span class="tc-val">${esc(t.mineral_system)}</span></div>
      <div class="tc-row"><span class="tc-label">Coordenadas</span>
        <span class="tc-val">${t.latitude.toFixed(4)}, ${t.longitude.toFixed(4)}</span></div>
      <div class="tc-row"><span class="tc-label">Raio</span><span class="tc-val">${t.radius_km} km</span></div>
      <div class="tc-row"><span class="tc-label">Confiança</span>
        <span class="tc-val t-conf-badge" style="background:${cColor}22;color:${cColor}">${cLabel}</span></div>
      ${t.rationale ? `<div class="tc-rationale">${esc(t.rationale)}</div>` : ''}
      ${followup.length ? `<div class="tc-followup">${followup.map(function(f) { return `<span class="tc-followup-tag">${esc(f)}</span>`; }).join('')}</div>` : ''}
      <div style="margin-top:8px">
        <button class="btn-fly" onclick="flyToTarget(${idx})">📍 Ver no mapa</button>
      </div>
    `;
    grid.appendChild(card);
  });

  pane.appendChild(grid);
}

// ============================================================
// TAB: QUALIDADE — Charts (lazy init, re-renderizável)
// ============================================================
let _confChart = null;
let _durChart = null;
let _radarChart = null;

function renderQualityCharts(r) {
  if (_confChart) { _confChart.destroy(); _confChart = null; }
  if (_durChart) { _durChart.destroy(); _durChart = null; }
  if (_radarChart) { _radarChart.destroy(); _radarChart = null; }

  const pane = document.getElementById('tab-qualidade');
  pane.innerHTML = `
    <div class="quality-charts">
      <div class="chart-card">
        <div class="chart-title">Confiança por Passo</div>
        <canvas id="chart-conf"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Duração por Passo (s)</div>
        <canvas id="chart-dur"></canvas>
      </div>
      <div class="chart-card">
        <div class="chart-title">Cobertura de Serviços GeoSGB</div>
        <canvas id="chart-radar"></canvas>
      </div>
    </div>
  `;
  window._chartsInited = true;

  Chart.defaults.color = '#94a3b8';
  Chart.defaults.borderColor = '#334155';

  const steps = r.steps || [];
  const stepLabels = steps.map(function(s) { return stepName(s.step); });

  _confChart = new Chart(document.getElementById('chart-conf'), {
    type: 'bar',
    data: {
      labels: stepLabels,
      datasets: [{
        label: 'Confiança',
        data: steps.map(function(s) { return CONF_SCORES[s.confidence] || 0; }),
        backgroundColor: steps.map(function(s) { return (CONF_COLORS[s.confidence] || '#6b7280') + 'cc'; }),
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: {display:false} },
      scales: {
        y: {
          min:0, max:3, stepSize:1,
          ticks: { callback: function(v) { return ['INSUF.','BAIXA','MÉDIA','ALTA'][v] || ''; } },
          grid: { color: '#334155' },
        },
        x: { grid: { display:false } },
      }
    }
  });

  _durChart = new Chart(document.getElementById('chart-dur'), {
    type: 'bar',
    data: {
      labels: stepLabels,
      datasets: [{
        label: 'Duração (s)',
        data: steps.map(function(s) { return +(s.duration_ms / 1000).toFixed(1); }),
        backgroundColor: '#f59e0bcc',
        borderRadius: 4,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: {display:false} },
      scales: {
        y: { grid: { color: '#334155' } },
        x: { grid: { display:false } },
      }
    }
  });

  const SERVICES = ['ocorrencias','gravimetria','geoquimica','geocronologia','litoestratigrafia','aerogeofisica'];
  const SVC_LABELS = ['Ocorrências','Gravimetria','Geoquímica','Geocronologia','Litoestratigr.','Aerogeofísica'];
  const svcCounts = SERVICES.map(function(svc) {
    return steps.filter(function(s) {
      return (s.data_sources_used || []).some(function(d) { return d.toLowerCase().includes(svc); });
    }).length;
  });
  _radarChart = new Chart(document.getElementById('chart-radar'), {
    type: 'radar',
    data: {
      labels: SVC_LABELS,
      datasets: [{
        label: 'Passos que usaram o serviço',
        data: svcCounts,
        backgroundColor: 'rgba(245,158,11,0.15)',
        borderColor: '#f59e0b',
        pointBackgroundColor: '#f59e0b',
        pointRadius: 3,
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: true,
      plugins: { legend: {display:false} },
      scales: {
        r: {
          min: 0, max: Math.max(steps.length, 1),
          ticks: { stepSize: 1, backdropColor: 'transparent' },
          grid: { color: '#334155' },
          pointLabels: { color: '#94a3b8', font: { size: 10 } },
          angleLines: { color: '#334155' },
        }
      }
    }
  });
}

